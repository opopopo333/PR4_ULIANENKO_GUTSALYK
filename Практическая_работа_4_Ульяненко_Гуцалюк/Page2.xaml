<Page x:Class="Практическая_работа_4_Ульяненко_Гуцалюк.Page2"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Практическая_работа_4_Ульяненко_Гуцалюк"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Page2">

    <Grid Margin="20,30,20,0">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="220"/>
        </Grid.ColumnDefinitions>

        <Image Source="/Img/2.png"
           Grid.Row="0"
           Grid.ColumnSpan="2"
           Height="60"
           HorizontalAlignment="Left"
           Margin="0,0,0,20"/>

        <TextBlock Text="x:"
               Grid.Row="1"
               Grid.Column="0"
               VerticalAlignment="Center"/>

        <TextBox x:Name="tbX"
             Grid.Row="1"
             Grid.Column="1"
             Height="30"
             Margin="0,5"/>

        <TextBlock Text="q:"
               Grid.Row="2"
               Grid.Column="0"
               VerticalAlignment="Center"/>

        <TextBox x:Name="tbQ"
             Grid.Row="2"
             Grid.Column="1"
             Height="30"
             Margin="0,5"/>

        <TextBlock Text="Выберите f(x):"
               FontWeight="Bold"
               Grid.Row="3"
               Grid.ColumnSpan="2"
               Margin="0,15,0,5"/>

        <StackPanel Grid.Row="4"
                Grid.ColumnSpan="2"
                Margin="20,0,0,10">

            <RadioButton x:Name="rbSh"
                     Content="sh(x)"
                     Margin="0,5"/>

            <RadioButton x:Name="rbX2"
                     Content="x²"
                     Margin="0,5"/>

            <RadioButton x:Name="rbExp"
                     Content="e^x"
                     Margin="0,5"/>

        </StackPanel>

        <StackPanel Grid.Row="5"
                Grid.ColumnSpan="2"
                Orientation="Horizontal"
                HorizontalAlignment="Left"
                Margin="0,10,0,0">

            <Button Content="Вычислить"
                Click="BtnCalc_Click"
                Width="120"
                Height="35"
                Margin="0,0,10,0"/>

            <Button Content="Очистить"
                Click="BtnClear_Click"
                Width="120"
                Height="35"/>

        </StackPanel>

        <TextBlock Text="Результат:"
               Grid.Row="6"
               Grid.Column="0"
               VerticalAlignment="Center"
               Margin="0,20,0,0"/>

        <TextBox x:Name="tbResult"
             Grid.Row="6"
             Grid.Column="1"
             Height="30"
             IsReadOnly="True"
             Margin="0,20,0,0"/>

    </Grid>
</Page>
