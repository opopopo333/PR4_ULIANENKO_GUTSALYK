<Page x:Class="Практическая_работа_4_Ульяненко_Гуцалюк.Page3"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:charts="clr-namespace:System.Windows.Forms.DataVisualization.Charting;assembly=System.Windows.Forms.DataVisualization"
      xmlns:local="clr-namespace:Практическая_работа_4_Ульяненко_Гуцалюк"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Page3">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
              HorizontalScrollBarVisibility="Disabled">

        <Grid Margin="20,30,20,0">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="100"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="250"/>
            </Grid.ColumnDefinitions>

            <Image Source="/Img/3.png"
               Grid.Row="0"
               Grid.ColumnSpan="2"
               Height="60"
               HorizontalAlignment="Left"
               Margin="0,0,0,20"/>

            <TextBlock Text="x0:"
                   Grid.Row="1"
                   Grid.Column="0"
                   VerticalAlignment="Center"/>

            <TextBox x:Name="tbX0" x:FieldModifier="public"
                 Grid.Row="1"
                 Grid.Column="1"
                 Height="30"
                 Margin="0,5"/>

            <TextBlock Text="xk:"
                   Grid.Row="2"
                   Grid.Column="0"
                   VerticalAlignment="Center"/>

            <TextBox x:Name="tbXk" x:FieldModifier="public"
                 Grid.Row="2"
                 Grid.Column="1"
                 Height="30"
                 Margin="0,5"/>

            <TextBlock Text="dx:"
                   Grid.Row="3"
                   Grid.Column="0"
                   VerticalAlignment="Center"/>

            <TextBox x:Name="tbDx" x:FieldModifier="public"
                 Grid.Row="3"
                 Grid.Column="1"
                 Height="30"
                 Margin="0,5"/>

            <TextBlock Text="b:"
                   Grid.Row="4"
                   Grid.Column="0"
                   VerticalAlignment="Center"/>

            <TextBox x:Name="tbB" x:FieldModifier="public"
                 Grid.Row="4"
                 Grid.Column="1"
                 Height="30"
                 Margin="0,5"/>

            <StackPanel Grid.Row="5"
                    Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    Margin="0,15,0,0">

                <Button Content="Вычислить"
                    Click="BtnCalc_Click"
                    Width="130"
                    Height="35"
                    Margin="0,0,10,0"/>

                <Button Content="Очистить"
                    Click="BtnClear_Click"
                    Width="130"
                    Height="35"/>
            </StackPanel>

            <TextBlock Text="Результаты:"
                   Grid.Row="6"
                   Grid.ColumnSpan="2"
                   Margin="0,20,0,5"
                   FontWeight="Bold"/>

            <TextBox x:Name="tbResult" x:FieldModifier="public"
                 Grid.Row="7"
                 Grid.ColumnSpan="2"
                 AcceptsReturn="True"
                 IsReadOnly="True"
                 VerticalScrollBarVisibility="Auto"
                 Margin="0,0,0,10"/>

            <WindowsFormsHost Grid.Row="8"
                          Grid.ColumnSpan="2"
                          Margin="0,10,0,0"
                          Height="250">

                <charts:Chart x:Name="ChartFunction">
                    <charts:Chart.Legends>
                        <charts:Legend />
                    </charts:Chart.Legends>
                </charts:Chart>

            </WindowsFormsHost>

        </Grid>

    </ScrollViewer>
</Page>
